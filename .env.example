
# ── Database ────────────────────────────────────────────────────────────────
DB_USER=user
DB_PASSWORD=db_password
DB_NAME=db_name
DB_PORT=db_port

DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}

# ── Backend ─────────────────────────────────────────────────────────────────
# Bind to localhost only so Nginx handles all external traffic
BACKEND_HOST=
BACKEND_PORT=

# Logging level: trace, debug, info, warn, error
RUST_LOG=

# JWT signing secret
JWT_SECRET=

# Access token lifetime in minutes
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=

# Refresh token lifetime in days
JWT_REFRESH_TOKEN_EXPIRY_DAYS=

# ── SQLx ────────────────────────────────────────────────────────────────────
# Set to true for CI/environments without a running database
# Note: This is read during `cargo build`, not at runtime!
SQLX_OFFLINE=
